# Afterglow environment variables (prototype)
#
# The prototype does not require any environment variables. The keys below
# are placeholders for the integrations that will be wired up when the
# backend, payment processor, and moderation services are added. Do not
# commit real secrets to this file. Copy to .env.local for your own
# development and fill in real values there if you are wiring up an
# integration.

# Public site URL. Used by canonical URLs and OG metadata when added.
NEXT_PUBLIC_SITE_URL=

# Backend API base URL. Empty in the prototype.
NEXT_PUBLIC_API_BASE_URL=

# Payment processor (Stripe is the planned default). Server-side only.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Auth provider (placeholder). Server-side only.
AUTH_SECRET=
AUTH_PROVIDER=

# Email delivery for transactional messages.
RESEND_API_KEY=

# AI-assisted moderation service. Server-side only.
# The prototype runs heuristics locally and does not call any API.
MODERATION_API_KEY=

# Analytics. Optional.
NEXT_PUBLIC_ANALYTICS_DOMAIN=
